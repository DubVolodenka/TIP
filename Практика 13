#include <iostream>
#include <array>
#include <numeric>
#include <algorithm>

using namespace std;

double avg(const array<int, 15>& g) {
    double sum = accumulate(g.begin(), g.end(), 0);
    return sum / g.size();
}

int count5(const array<int, 15>& g) {
    return count(g.begin(), g.end(), 5);
}

int countFail(const array<int, 15>& g) {
    return count_if(g.begin(), g.end(), [](int x) { return x <= 2; });
}

void stat(const array<int, 15>& g) {

    for (int i = 1; i <= 5; ++i) {
        int n = count(g.begin(), g.end(), i);
        cout << "Grade " << i << ": ";
        for (int j = 0; j < n; ++j) {
            cout << "*";
        }
        cout << " (" << n << ")" << endl;
    }
}

int main() {
    const int N = 15;
    array<int, N> g;


    for (int i = 0; i < N; ++i) {
        int x;
        do {
            cout << "Student " << i + 1 << ": (1-5): ";
            cin >> x;

            if (cin.fail()) {
                cin.clear();
                cin.ignore(10000, '\n');
                x = 0;
            }

            if (x < 1 || x > 5) {
                cout << "Error! input 1-5" << endl;
            }
        } while (x < 1 || x > 5);

        g[i] = x;
    }

    cout << "Avg: " << avg(g) << endl;
    cout << "5: " << count5(g) << endl;
    cout << "<=2: " << countFail(g) << endl;
    cout << "Statistic: " << (N - countFail(g)) * 100.0 / N << endl;

    stat(g);

    return 0;
}

