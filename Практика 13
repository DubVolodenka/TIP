#include <iostream>
#include <array>

using namespace std;

void printAr(const array<int, 10>& ar) {
    for (size_t i = 0; i < ar.size(); ++i) {
        cout << ar[i];
        if (i < ar.size() - 1) {
            cout << " ";
        }
    }
    cout << endl;
}

int sumAr(const array<int, 10>& ar) {
    int sum = 0;
    for (int num : ar) {
        sum += num;
    }
    return sum;
}

double midl(const array<int, 10>& ar) {
    if (ar.size() == 0) return 0.0;
    return static_cast<double>(sumAr(ar)) / ar.size();
}

int findMax(const array<int, 10>& ar) {
    int max = ar[0];
    for (int num : ar) {
        if (num > max) {
            max = num;
        }
    }
    return max;
}

int findMin(const array<int, 10>& ar) {
    int min = ar[0];
    for (int num : ar) {
        if (num < min) {
            min = num;
        }
    }
    return min;
}

int main() {
    array<int, 10> ar;
    for (int i = 0; i < 10; ++i) {
        ar[i] = i;
    }


    printAr(ar);

    cout << sumAr(ar) << endl;
    cout << midl(ar) << endl;
    cout << findMax(ar) << endl;
    cout << findMin(ar) << endl;

    ar.fill(42);
    
    printAr(ar);

    array<int, 10> precopy;
    for (int i = 0; i < 10; ++i) {
        precopy[i] = i * 10;
    }

    array<int, 10> copyAr = precopy;
    copyAr[0] = 52;

  
    printAr(precopy);
   
    printAr(copyAr);

    return 0;
}

