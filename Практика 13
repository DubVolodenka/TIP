#include <iostream>
#include <vector>
#include <string>
#include <algorithm>

using namespace std;

struct Task {
    string desc;
    int prio;
    bool done;
};

bool cmp(const Task& a, const Task& b) {
    return a.prio < b.prio;
}

int main() {
    vector<Task> t;
    int c;

    while (true) {
        cout << "1 - Add task" << endl;
        cout << "2 - Mark completed" << endl;
        cout << "3 - Delete task" << endl;
        cout << "4 - All tasks" << endl;
        cout << "5 - Uncompleted tasks" << endl;
        cout << "6 - By priority" << endl;
        cout << "0 - Exit" << endl;
        cout << "Choice: ";
        cin >> c;
        cin.ignore();

        switch (c) {
        case 0:
            return 0;

        case 1: {
            Task x;
            cout << "Description: ";
            getline(cin, x.desc);
            cout << "Priority (1-high, 2-medium, 3-low): ";
            cin >> x.prio;
            x.done = false;
            t.push_back(x);
            cout << "Added" << endl;
            break;
        }

        case 2: {
            int n;
            cout << "Task number: ";
            cin >> n;
            if (n >= 1 && n <= t.size()) {
                t[n - 1].done = true;
                cout << "Marked" << endl;
            }
            else {
                cout << "Wrong number" << endl;
            }
            break;
        }

        case 3: {
            int n;
            cout << "Task number: ";
            cin >> n;
            if (n >= 1 && n <= t.size()) {
                t.erase(t.begin() + (n - 1));
                cout << "Deleted" << endl;
            }
            else {
                cout << "Wrong number" << endl;
            }
            break;
        }

        case 4: {
            if (t.empty()) {
                cout << "List is empty" << endl;
            }
            else {
                for (int i = 0; i < t.size(); i++) {
                    cout << i + 1 << ". [" << (t[i].done ? "V" : " ") << "] ";
                    cout << t[i].desc << " (priority: " << t[i].prio << ")" << endl;
                }
            }
            break;
        }

        case 5: {
            bool f = false;
            for (int i = 0; i < t.size(); i++) {
                if (!t[i].done) {
                    cout << i + 1 << ". " << t[i].desc;
                    cout << " (priority: " << t[i].prio << ")" << endl;
                    f = true;
                }
            }
            if (!f) {
                cout << "All tasks completed" << endl;
            }
            break;
        }

        case 6: {
            if (t.empty()) {
                cout << "List is empty" << endl;
            }
            else {
                vector<Task> s = t;
                sort(s.begin(), s.end(), cmp);
                for (int i = 0; i < s.size(); i++) {
                    cout << i + 1 << ". [" << (s[i].done ? "V" : " ") << "] ";
                    cout << s[i].desc << " (priority: " << s[i].prio << ")" << endl;
                }
            }
            break;
        }

        default:
            cout << "Wrong choice" << endl;
            break;
        }
    }

    return 0;
}

