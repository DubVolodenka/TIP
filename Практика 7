задание 2
#include<iostream>
#include<vector>
using namespace std;
class shape {
public:
    virtual ~shape() = default;
    virtual double area() const = 0;
    virtual void print() const = 0;
};
class circle : public shape {
private:
    double rad;
public:
    circle(double r) : rad(r) {}
    double area() const override {
    return 3.14 * rad * rad;
    }
    void print() const override {
    cout << "radius = " << rad << endl
    << "area = " << area() << endl;
    }
    double getrad() const { return rad; }
};
class rectangle : public shape {
private:
    double w, h;
public:
    rectangle(double a, double b) : w(a), h(b) {}
    double area() const override {
    return w * h;
    }
    void print() const override {
    cout << "width = " << w << endl
    << "height = " << h << endl
    << "area = " << area() << endl;
    }
    double getw() const { return w; }
    double geth() const { return h; }
};
int main() {
    vector<shape*> shapes;
    shapes.push_back(new circle(3.0));
    shapes.push_back(new rectangle(4.0, 5.0));

    //статическое приведение
    circle* c = static_cast<circle*>(shapes[0]);
    cout << c->getrad() << endl;

    rectangle* r = static_cast<rectangle*>(shapes[1]);
    cout << r->getw() << endl;

    //ошибка
    rectangle* er = static_cast<rectangle*>(shapes[0]);
    cout << er->getw() << endl;

    for (shape* x : shapes) {
        delete x;
    }
    return 0;
}
